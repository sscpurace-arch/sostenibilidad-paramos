# Copia este archivo a .env.local y completa los valores reales.
# NUNCA subas .env.local al repositorio.

# Supabase (la anon key es pública por diseño; la protección real es RLS)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Notificaciones Telegram (solo servidor)
TELEGRAM_BOT_TOKEN=123456789:AA...
TELEGRAM_CHAT_ID=123456789

# Llave compartida para proteger /api/notificar (mismo valor en ambas)
NOTIFY_SECRET=una-cadena-aleatoria-larga
NEXT_PUBLIC_NOTIFY_KEY=una-cadena-aleatoria-larga

# Gemini (solo se usa en la Edge Function de Supabase, no en la app)
GEMINI_API_KEY=AIza...
